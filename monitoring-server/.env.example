# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/vibgyorseek_monitoring
# For MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vibgyorseek_monitoring?retryWrites=true&w=majority

# Screenshot Storage
SCREENSHOT_STORAGE_PATH=./screenshots
SCREENSHOT_TTL_DAYS=30

# Authentication
CLIENT_AUTH_TOKEN=your-secure-client-token-here
JWT_SECRET=your-secure-jwt-secret-here

# Logging
LOG_LEVEL=info

# Shift Time Configuration (24-hour format: 0-23)
# Timeline will display data between these hours
SHIFT_START_HOUR=9
SHIFT_END_HOUR=20
# File Upload Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_UPLOAD_SIZE_MB=100

# SMTP Configuration for Email Reports
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your-gmail-app-password
